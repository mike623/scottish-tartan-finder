---
import type { TartanRecord } from '../lib/tartans';
import { imageSrc } from '../lib/tartans';
import { base } from '../lib/base';

interface Props {
  tartan: TartanRecord;
  cta?: boolean;
  compact?: boolean;
}

const { tartan, cta = false, compact = false } = Astro.props;
const meta = [tartan.designer, tartan.tartanDate].filter(Boolean).join(' · ');
const href = `${base}tartan/${tartan.ref}`;
---

<a
  class="tf-card"
  href={href}
  data-ref={tartan.ref}
  data-name={tartan.name.toLowerCase()}
  data-category={tartan.category}
  data-category-lc={tartan.category.toLowerCase()}
  data-designer={tartan.designer.toLowerCase()}
  data-date={tartan.tartanDate}
>
  <div style="aspect-ratio:4/3;position:relative;overflow:hidden;background:#e9e1cf;background-image:repeating-linear-gradient(135deg,#e2d8bd 0 7px,#ece5d3 7px 15px);">
    <span style="position:absolute;left:10px;bottom:10px;z-index:1;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.06em;color:#8a7d5f;background:rgba(251,248,241,.85);padding:3px 7px;border:1px solid #ded3ba;">tartan preview</span>
    <img src={imageSrc(tartan)} alt={`${tartan.name} tartan pattern`} loading="lazy" decoding="async" onerror="this.remove()" style="position:absolute;inset:0;z-index:2;width:100%;height:100%;object-fit:cover;background:#e9e1cf;" />
  </div>
  {compact ? (
    <div style="padding:14px 15px 16px;">
      <h3 style="font-size:1.4rem;line-height:1.1;margin:0 0 5px;">{tartan.name}</h3>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#8a7d5f;">Ref {tartan.ref}</div>
    </div>
  ) : (
    <div style="padding:15px 16px 18px;">
      <span style="display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:500;letter-spacing:.09em;text-transform:uppercase;color:#2f5140;background:#eef0e7;border:1px solid #d9dcc9;padding:3px 8px;">{tartan.category}</span>
      <h3 style="font-size:1.55rem;line-height:1.08;margin:11px 0 5px;">{tartan.name}</h3>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#8a7d5f;">Ref {tartan.ref}</div>
      {meta && <div style="font-size:13px;color:#6b6455;margin-top:7px;">{meta}</div>}
      {cta && <div style="margin-top:13px;font-size:13px;font-weight:600;color:#2f5140;">View details →</div>}
    </div>
  )}
</a>
