---
import Layout from '../../layouts/Layout.astro';
import TartanCard from '../../components/TartanCard.astro';
import { tartans, similarTartans } from '../../lib/tartans';
import type { TartanRecord } from '../../lib/tartans';
import { base } from '../../lib/base';

export function getStaticPaths() {
  return tartans.map((t) => ({
    params: { ref: String(t.ref) },
    props: { tartan: t },
  }));
}

interface Props {
  tartan: TartanRecord;
}

const { tartan } = Astro.props as Props;
const REGISTER_URL = 'https://www.tartanregister.gov.uk';
const similar = similarTartans(tartan, 3);

const rows: Array<[string, string]> = [
  ['Reference ID', String(tartan.ref)],
  ['Category', tartan.category],
  ['Designer', tartan.designer || 'Not recorded'],
  ['Tartan date', tartan.tartanDate || 'Not recorded'],
  ['Registration date', tartan.registrationDate || 'Not recorded'],
  ['Notes', tartan.registrationNotes || '—'],
];
---

<Layout title={`${tartan.name} — Scottish Tartan Finder`} description={`Ref ${tartan.ref} · ${tartan.category} tartan. ${tartan.registrationNotes || ''}`.trim()}>
  <div style="max-width:1180px;margin:0 auto;padding:clamp(24px,3cqw,40px) clamp(18px,5cqw,48px) 72px;">
    <a href={`${base}search`} style="display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:500;color:#6b6455;cursor:pointer;margin-bottom:26px;text-decoration:none;">← Back to search</a>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(28px,4cqw,48px);align-items:start;">
      <div>
        <div id="tf-image-frame" style="aspect-ratio:1/1;background:#e9e1cf;background-image:repeating-linear-gradient(135deg,#e0d6ba 0 9px,#ece5d3 9px 19px);border:1px solid #e4dcc9;border-radius:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;position:relative;overflow:hidden;">
          <img
            id="tf-tartan-image"
            src={tartan.imageUrl}
            alt={`${tartan.name} tartan pattern`}
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;display:block;"
          />
          <span id="tf-image-fallback" style="display:none;font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.1em;color:#8a7d5f;background:rgba(251,248,241,.9);padding:6px 12px;border:1px solid #ded3ba;">image not yet available</span>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;">
          <button id="tf-open-lightbox" type="button" style="flex:1;min-width:150px;background:#2f5140;color:#f6f1e7;border:none;padding:13px 18px;font-weight:600;font-size:14px;cursor:pointer;border-radius:2px;">Open tartan image ↗</button>
          <a href={tartan.detailUrl} target="_blank" rel="noopener" style="flex:1;min-width:150px;text-align:center;background:transparent;border:1px solid #cdbf9f;color:#3a3428;padding:13px 18px;font-weight:600;font-size:14px;border-radius:2px;text-decoration:none;">Official Register ↗</a>
        </div>
        <div style="margin-top:18px;padding:16px 18px;border:1px solid #e0d7c3;background:#faf6ec;border-radius:3px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#a67c2e;margin-bottom:7px;">Similar tartans · coming soon</div>
          <p style="margin:0;font-size:13px;line-height:1.6;color:#6b6455;">Visual matching against related designs is planned for a future release. For now, browse others in this category below.</p>
        </div>
      </div>
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.08em;color:#8a7d5f;margin-bottom:12px;">Ref {tartan.ref} · Scottish Register of Tartans</div>
        <h1 style="font-size:clamp(2.6rem,6cqw,4.4rem);line-height:.98;letter-spacing:-.01em;">{tartan.name}</h1>
        <div style="margin:16px 0 26px;">
          <span style="display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:#2f5140;background:#eef0e7;border:1px solid #d9dcc9;padding:5px 11px;">{tartan.category}</span>
        </div>
        {tartan.restrictions && (
          <div style="margin-bottom:24px;padding:15px 18px;border:1px solid #dcbdc0;background:#f6ebe9;border-radius:3px;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#6d2532;margin-bottom:6px;">Restrictions</div>
            <p style="margin:0;font-size:14px;line-height:1.6;color:#5a3a3d;">{tartan.restrictions}</p>
          </div>
        )}
        <dl style="margin:0;border-top:1px solid #e0d7c3;">
          {rows.map(([dt, dd]) => (
            <div style="display:grid;grid-template-columns:minmax(120px,180px) 1fr;gap:16px;padding:15px 0;border-bottom:1px solid #e0d7c3;">
              <dt style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#8a7d5f;">{dt}</dt>
              <dd style="margin:0;font-size:15px;line-height:1.6;color:#211d16;">{dd}</dd>
            </div>
          ))}
        </dl>
        <div style="margin-top:26px;padding:18px 20px;border:1px solid #d3c8ae;background:#efe8db;border-radius:3px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#8a7d5f;margin-bottom:8px;">Source &amp; disclaimer</div>
          <p style="margin:0;font-size:13.5px;line-height:1.7;color:#5c5647;">This record is attributed to the <a href={REGISTER_URL} target="_blank" rel="noopener" style="font-weight:600;">Scottish Register of Tartans</a>. Scottish Tartan Finder is an independent, unofficial project and is not affiliated with or endorsed by the Register. Always consult the official entry for authoritative details.</p>
        </div>
      </div>
    </div>
    {similar.length > 0 && (
      <div style="margin-top:56px;">
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
          <h2 style="font-size:1.9rem;">More in {tartan.category}</h2>
          <div style="flex:1;height:1px;background:#e0d7c3;"></div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:18px;">
          {similar.map((t) => <TartanCard tartan={t} compact />)}
        </div>
      </div>
    )}
  </div>

  <div id="tf-lightbox" style="display:none;position:fixed;inset:0;z-index:80;background:rgba(20,18,14,.86);backdrop-filter:blur(4px);flex-direction:column;align-items:center;justify-content:center;gap:18px;padding:24px;">
    <div style="width:min(88cqw,560px);aspect-ratio:1/1;background:#e9e1cf;border:1px solid #cdbf9f;overflow:hidden;display:flex;align-items:center;justify-content:center;">
      <img src={tartan.imageUrl} alt={`${tartan.name} tartan pattern, enlarged`} style="width:100%;height:100%;object-fit:contain;" />
    </div>
    <button id="tf-close-lightbox" type="button" style="background:rgba(246,241,231,.12);border:1px solid rgba(236,228,211,.4);color:#ece4d3;padding:11px 22px;font-size:14px;font-weight:500;cursor:pointer;border-radius:2px;">Close</button>
  </div>

  <script is:inline>
    (function () {
      var img = document.getElementById('tf-tartan-image');
      var fallback = document.getElementById('tf-image-fallback');
      if (img) {
        img.addEventListener('error', function () {
          img.style.display = 'none';
          if (fallback) fallback.style.display = 'inline-block';
        });
      }

      var lightbox = document.getElementById('tf-lightbox');
      var openBtn = document.getElementById('tf-open-lightbox');
      var closeBtn = document.getElementById('tf-close-lightbox');
      if (lightbox && openBtn && closeBtn) {
        openBtn.addEventListener('click', function () { lightbox.style.display = 'flex'; });
        closeBtn.addEventListener('click', function () { lightbox.style.display = 'none'; });
        lightbox.addEventListener('click', function (e) {
          if (e.target === lightbox) lightbox.style.display = 'none';
        });
      }
    })();
  </script>
</Layout>
