---
import Layout from '../layouts/Layout.astro';
import { categoryCounts } from '../lib/tartans';
import { base } from '../lib/base';

const counts = categoryCounts();
const categories = Object.keys(counts).sort();
const total = Object.values(counts).reduce((a, b) => a + b, 0);
---

<Layout title="Search — Scottish Tartan Finder" active="search">
  <div style="max-width:1180px;margin:0 auto;padding:clamp(30px,4cqw,52px) clamp(18px,5cqw,48px) 72px;">
    <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8a7d5f;margin-bottom:10px;">Search the catalogue</div>
    <h1 style="font-size:clamp(2.2rem,5cqw,3.4rem);line-height:1.02;margin-bottom:22px;">Find a tartan</h1>
    <div style="display:flex;background:#fbf8f1;border:1px solid #d8cdb4;border-radius:2px;overflow:hidden;max-width:640px;">
      <input id="q" placeholder="Search name, designer, notes, district or reference…" style="flex:1;border:none;outline:none;background:transparent;padding:15px 18px;font-size:16px;color:#211d16;" />
      <div style="display:flex;align-items:center;padding:0 16px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:#8a7d5f;border-left:1px solid #e4dcc9;">↵</div>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin:26px 0 8px;padding-bottom:18px;border-bottom:1px solid #e0d7c3;">
      <div id="chips" style="display:flex;gap:8px;flex-wrap:wrap;">
        <span class="tf-chip is-active" data-cat="All">All</span>
        {categories.map((c) => <span class="tf-chip" data-cat={c}>{c}</span>)}
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;color:#8a7d5f;text-transform:uppercase;">Sort</span>
        <select id="sort" style="border:1px solid #d8cdb4;background:#fbf8f1;padding:9px 12px;font-size:14px;color:#211d16;border-radius:2px;cursor:pointer;">
          <option value="name">Name A–Z</option>
          <option value="ref">Reference ID</option>
          <option value="cat">Category</option>
        </select>
      </div>
    </div>
    <div id="count-label" style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#6b6455;margin:14px 0 22px;">Loading catalogue…</div>
    <div id="results" data-base={base} data-total={total} style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:18px;"></div>
    <div id="sentinel" style="height:1px;"></div>
    <div id="empty-state" style="display:none;text-align:center;padding:64px 24px;border:1px dashed #d3c8ae;border-radius:4px;background:#faf6ec;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8a7d5f;">No matches</div>
      <h3 style="font-size:1.9rem;margin:12px 0 8px;">Nothing found for that search</h3>
      <p style="color:#6b6455;max-width:44ch;margin:0 auto 22px;line-height:1.6;">Try a shorter term, a clan or district name, or clear the filters to see the full catalogue.</p>
      <button id="clear-filters" type="button" style="background:#2f5140;color:#f6f1e7;border:none;padding:12px 24px;font-weight:600;font-size:14px;cursor:pointer;border-radius:2px;">Clear search &amp; filters</button>
    </div>
  </div>

  <script is:inline>
    (function () {
      var grid = document.getElementById('results');
      var BASE = grid.dataset.base;
      var qInput = document.getElementById('q');
      var chipsWrap = document.getElementById('chips');
      var sortSelect = document.getElementById('sort');
      var countLabel = document.getElementById('count-label');
      var emptyState = document.getElementById('empty-state');
      var sentinel = document.getElementById('sentinel');
      var clearBtn = document.getElementById('clear-filters');
      var BATCH = 48;

      var params = new URLSearchParams(location.search);
      var state = { q: params.get('q') || '', cat: params.get('cat') || 'All', sort: 'name' };
      qInput.value = state.q;

      var all = [];
      var filtered = [];
      var shown = 0;

      function esc(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      function cardHTML(t) {
        var img = 'https://www.tartanregister.gov.uk/imageCreation?height=360&ref=' + t.r + '&width=360';
        var meta = [t.d, t.y].filter(Boolean).join(' · ');
        return '<a class="tf-card" href="' + BASE + 'tartan/' + t.r + '">' +
          '<div class="tf-prev"><span class="tf-prev-label">tartan preview</span>' +
          '<img src="' + img + '" alt="' + esc(t.n) + ' tartan pattern" loading="lazy" decoding="async" onerror="this.remove()"></div>' +
          '<div style="padding:15px 16px 18px;">' +
          '<span class="tf-badge">' + esc(t.c) + '</span>' +
          '<h3 style="font-size:1.55rem;line-height:1.08;margin:11px 0 5px;">' + esc(t.n) + '</h3>' +
          '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:11.5px;color:#8a7d5f;">Ref ' + t.r + '</div>' +
          (meta ? '<div style="font-size:13px;color:#6b6455;margin-top:7px;">' + esc(meta) + '</div>' : '') +
          '<div style="margin-top:13px;font-size:13px;font-weight:600;color:#2f5140;">View details →</div>' +
          '</div></a>';
      }

      function applyFilter() {
        var q = state.q.trim().toLowerCase();
        filtered = all.filter(function (t) {
          var okC = state.cat === 'All' || t.c === state.cat;
          if (!okC) return false;
          if (!q) return true;
          return t.n.toLowerCase().indexOf(q) !== -1 || String(t.r).indexOf(q) !== -1 ||
            (t.d || '').toLowerCase().indexOf(q) !== -1 || t.c.toLowerCase().indexOf(q) !== -1 ||
            (t.o || '').toLowerCase().indexOf(q) !== -1;
        });
        if (state.sort === 'ref') filtered.sort(function (a, b) { return a.r - b.r; });
        else if (state.sort === 'cat') filtered.sort(function (a, b) { return a.c.localeCompare(b.c) || a.n.localeCompare(b.n); });
        else filtered.sort(function (a, b) { return a.n.localeCompare(b.n); });

        grid.innerHTML = '';
        shown = 0;
        renderMore();

        var n = filtered.length;
        var label = n + (n === 1 ? ' tartan' : ' tartans');
        if (state.cat !== 'All') label += ' in ' + state.cat;
        if (q) label += ' matching “' + state.q.trim() + '”';
        countLabel.textContent = label;
        emptyState.style.display = n === 0 ? 'block' : 'none';
        grid.style.display = n === 0 ? 'none' : 'grid';

        var url = new URL(location.href);
        if (state.q) url.searchParams.set('q', state.q); else url.searchParams.delete('q');
        if (state.cat !== 'All') url.searchParams.set('cat', state.cat); else url.searchParams.delete('cat');
        history.replaceState({}, '', url);
      }

      function renderMore() {
        if (shown >= filtered.length) return;
        var next = filtered.slice(shown, shown + BATCH);
        var html = '';
        for (var i = 0; i < next.length; i++) html += cardHTML(next[i]);
        grid.insertAdjacentHTML('beforeend', html);
        shown += next.length;
      }

      var io = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) renderMore();
      }, { rootMargin: '600px 0px' });
      io.observe(sentinel);

      function setChips() {
        Array.prototype.forEach.call(chipsWrap.querySelectorAll('.tf-chip'), function (chip) {
          chip.classList.toggle('is-active', chip.dataset.cat === state.cat);
        });
      }

      qInput.addEventListener('input', function (e) { state.q = e.target.value; applyFilter(); });
      sortSelect.addEventListener('change', function (e) { state.sort = e.target.value; applyFilter(); });
      chipsWrap.addEventListener('click', function (e) {
        var chip = e.target.closest('.tf-chip');
        if (!chip) return;
        state.cat = chip.dataset.cat; setChips(); applyFilter();
      });
      clearBtn.addEventListener('click', function () {
        state.q = ''; state.cat = 'All'; qInput.value = ''; setChips(); applyFilter();
      });

      fetch(BASE + 'tartans-search.json')
        .then(function (r) { return r.json(); })
        .then(function (data) { all = data; setChips(); applyFilter(); })
        .catch(function () { countLabel.textContent = 'Could not load the catalogue.'; });
    })();
  </script>
</Layout>
