---
import Layout from '../layouts/Layout.astro';

const GITHUB_URL = 'https://github.com/scottish-tartan-finder/catalogue';
const REGISTER_URL = 'https://www.tartanregister.gov.uk';
---

<Layout title="About — Scottish Tartan Finder" active="about">
  <div>
    <section style="position:relative;background:radial-gradient(130% 120% at 30% -20%,#3b424a 0%,#242a30 50%,#171b20 100%);color:#ece4d3;overflow:hidden;">
      <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(115deg,rgba(255,255,255,.028) 0 2px,transparent 2px 24px);pointer-events:none;"></div>
      <div style="max-width:1180px;margin:0 auto;padding:clamp(48px,7cqw,88px) clamp(18px,5cqw,48px);position:relative;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:#c9b98a;margin-bottom:20px;">About the project</div>
        <h1 style="font-size:clamp(2.6rem,7cqw,5rem);line-height:.98;max-width:16ch;">A respectful, independent window on Scottish tartan.</h1>
      </div>
    </section>
    <section style="max-width:820px;margin:0 auto;padding:clamp(44px,6cqw,72px) clamp(18px,5cqw,48px);">
      <p style="font-size:clamp(17px,2cqw,20px);line-height:1.7;color:#3a3428;margin:0 0 22px;">Scottish Tartan Finder is a static, community reference catalogue for exploring Scottish tartans. It exists to make public tartan records easier to search, read and understand — with plain typography, no accounts, and no clutter.</p>
      <p style="font-size:16px;line-height:1.75;color:#5c5647;margin:0 0 34px;">The catalogue is intentionally modest in scope: it presents attributed public information and links back to authoritative sources rather than trying to replace them.</p>
      <div style="padding:24px 26px;border:1px solid #d3c8ae;background:#efe8db;border-radius:3px;margin-bottom:34px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#8a7d5f;margin-bottom:12px;">Source attribution</div>
        <p style="margin:0 0 14px;font-size:15px;line-height:1.75;color:#3a3428;">Tartan records shown here are attributed to the <strong>Scottish Register of Tartans</strong>, maintained by the National Records of Scotland. Where available, each entry links to its official Register page so you can verify the authoritative record.</p>
        <a href={REGISTER_URL} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;font-weight:600;font-size:15px;text-decoration:none;">Visit the Scottish Register of Tartans ↗</a>
      </div>
      <div style="padding:24px 26px;border:1px solid #dcbdc0;background:#f6ebe9;border-radius:3px;margin-bottom:40px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#6d2532;margin-bottom:12px;">Unofficial — please read</div>
        <p style="margin:0;font-size:15px;line-height:1.75;color:#5a3a3d;">Scottish Tartan Finder is an <strong>independent, unofficial project</strong>. It is not affiliated with, endorsed by, or connected to the Scottish Register of Tartans, the National Records of Scotland, or any government body. Information may be incomplete or out of date — for authoritative details, always consult the official Register.</p>
      </div>
      <h2 style="font-size:2rem;margin-bottom:16px;">How it works</h2>
      <p style="font-size:16px;line-height:1.75;color:#5c5647;margin:0 0 14px;">The site is built as static pages — every tartan has its own page, generated ahead of time from a published dataset. Search and filtering run entirely in your browser, with no login, no tracking database, and no live backend. That keeps it fast, private, and simple to host.</p>
      <p style="font-size:16px;line-height:1.75;color:#5c5647;margin:0 0 34px;">The project is open source. Contributions, corrections and attribution improvements are welcome.</p>
      <a href={GITHUB_URL} target="_blank" rel="noopener" style="display:inline-block;background:#2f5140;color:#f6f1e7;padding:14px 26px;font-weight:600;font-size:15px;border-radius:2px;text-decoration:none;">View the project on GitHub ↗</a>
    </section>
  </div>
</Layout>
