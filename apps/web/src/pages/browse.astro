---
import Layout from '../layouts/Layout.astro';
import { tartans, letterOf } from '../lib/tartans';
import { base } from '../lib/base';

const counts: Record<string, number> = {};
for (const t of tartans) {
  const l = letterOf(t);
  counts[l] = (counts[l] || 0) + 1;
}
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
---

<Layout title="Browse A–Z — Scottish Tartan Finder" active="browse">
  <div style="max-width:1180px;margin:0 auto;padding:clamp(30px,4cqw,52px) clamp(18px,5cqw,48px) 72px;">
    <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8a7d5f;margin-bottom:10px;">Alphabetical index</div>
    <h1 style="font-size:clamp(2.2rem,5cqw,3.4rem);line-height:1.02;margin-bottom:8px;">Browse A–Z</h1>
    <p style="color:#6b6455;max-width:56ch;line-height:1.6;margin:0 0 26px;">Every tartan in the catalogue, ordered by name. Pick a letter to see just those tartans, or “All” for the full list.</p>
    <div id="az-bar" style="display:flex;flex-wrap:wrap;gap:6px;padding:16px;background:#faf6ec;border:1px solid #e4dcc9;border-radius:3px;margin-bottom:34px;scroll-margin-top:80px;">
      <a data-letter="All" class="tf-az is-active" href="?letter=All">All</a>
      {alphabet.map((letter) => {
        const disabled = !counts[letter];
        return disabled ? (
          <span class="tf-az-disabled">{letter}</span>
        ) : (
          <a data-letter={letter} class="tf-az" href={`?letter=${letter}`}>{letter}</a>
        );
      })}
    </div>
    <div id="list" data-base={base}></div>
    <div id="sentinel" style="height:1px;"></div>
  </div>

  <script is:inline>
    (function () {
      var list = document.getElementById('list');
      var BASE = list.dataset.base;
      var sentinel = document.getElementById('sentinel');
      var azBar = document.getElementById('az-bar');
      var navLinks = azBar.querySelectorAll('.tf-az');
      var BATCH = 60;

      var all = [];      // full list, sorted by name
      var view = [];     // current letter's slice (or all)
      var letter = new URLSearchParams(location.search).get('letter') || 'All';
      var pos = 0;
      var curLetter = null;
      var curGrid = null;

      function esc(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }
      function cardHTML(t) {
        var img = 'https://www.tartanregister.gov.uk/imageCreation?height=360&ref=' + t.r + '&width=360';
        var meta = [t.d, t.y].filter(Boolean).join(' · ');
        return '<a class="tf-card" href="' + BASE + 'tartan/' + t.r + '">' +
          '<div class="tf-prev"><span class="tf-prev-label">tartan preview</span>' +
          '<img src="' + img + '" alt="' + esc(t.n) + ' tartan pattern" loading="lazy" decoding="async" onerror="this.remove()"></div>' +
          '<div style="padding:15px 16px 18px;">' +
          '<span class="tf-badge">' + esc(t.c) + '</span>' +
          '<h3 style="font-size:1.55rem;line-height:1.08;margin:11px 0 5px;">' + esc(t.n) + '</h3>' +
          '<div style="font-family:\'IBM Plex Mono\',monospace;font-size:11.5px;color:#8a7d5f;">Ref ' + t.r + '</div>' +
          (meta ? '<div style="font-size:13px;color:#6b6455;margin-top:7px;">' + esc(meta) + '</div>' : '') +
          '</div></a>';
      }
      function startLetter(l) {
        var block = document.createElement('div');
        block.style.cssText = 'margin-bottom:38px;';
        block.innerHTML = '<div style="display:flex;align-items:center;gap:16px;margin-bottom:18px;">' +
          '<div style="font-family:\'Cormorant Garamond\',serif;font-size:2.4rem;font-weight:700;color:#2f5140;line-height:1;">' + l + '</div>' +
          '<div style="flex:1;height:1px;background:#e0d7c3;"></div></div>';
        var grid = document.createElement('div');
        grid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:18px;';
        block.appendChild(grid);
        list.appendChild(block);
        curLetter = l;
        curGrid = grid;
      }
      function renderMore() {
        if (pos >= view.length) return;
        var end = Math.min(pos + BATCH, view.length);
        for (; pos < end; pos++) {
          var t = view[pos];
          var l = t.n.charAt(0).toUpperCase();
          if (l !== curLetter) startLetter(l);
          curGrid.insertAdjacentHTML('beforeend', cardHTML(t));
        }
      }
      function show(target, scroll) {
        letter = target;
        for (var i = 0; i < navLinks.length; i++) {
          navLinks[i].classList.toggle('is-active', navLinks[i].dataset.letter === letter);
        }
        view = letter === 'All' ? all : all.filter(function (t) { return t.n.charAt(0).toUpperCase() === letter; });
        list.innerHTML = '';
        pos = 0; curLetter = null; curGrid = null;
        renderMore();
        var url = new URL(location.href);
        if (letter === 'All') url.searchParams.delete('letter'); else url.searchParams.set('letter', letter);
        history.replaceState({}, '', url);
        if (scroll) azBar.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      var io = new IntersectionObserver(function (e) { if (e[0].isIntersecting) renderMore(); }, { rootMargin: '800px 0px' });
      io.observe(sentinel);

      for (var i = 0; i < navLinks.length; i++) {
        navLinks[i].addEventListener('click', function (ev) {
          ev.preventDefault();
          show(this.dataset.letter, true);
        });
      }

      fetch(BASE + 'tartans-lite.json')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          all = data.sort(function (a, b) { return a.n.localeCompare(b.n); });
          show(letter, false);
        });
    })();
  </script>
</Layout>
