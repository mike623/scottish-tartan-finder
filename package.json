{
  "name": "scottish-tartan-finder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "preview": "npm run preview -w apps/web",
    "crawl:discover": "npm run discover -w packages/scraper",
    "crawl:details": "npm run details -w packages/scraper",
    "crawl:smoke": "npm run smoke -w packages/scraper",
    "crawl:sync": "npm run sync -w packages/scraper --",
    "test": "npm test --workspaces --if-present"
  }
}
