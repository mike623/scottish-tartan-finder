---
import '../styles/global.css';
const sample = (await import('../../data/tartans-index.sample.json')).default;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Scottish Tartan Finder</title>
    <meta name="description" content="Unofficial static catalogue concept for searching and browsing Scottish tartans." />
  </head>
  <body>
    <main class="wrap">
      <section class="hero">
        <p class="eyebrow">Unofficial reference tool</p>
        <h1 class="title">Scottish Tartan Finder</h1>
        <p class="lede">Search and browse an attributed static catalogue of publicly listed Scottish tartans. Verify authoritative records at the Scottish Register of Tartans.</p>
        <form class="search" action="#">
          <input type="search" placeholder="Search tartan name, clan, family, district…" aria-label="Search tartans" />
          <button class="button">Search</button>
        </form>
        <div class="notice">Planning scaffold only. See <a href="./docs/PRD.md">PRD</a> and <a href="./docs/design-agent-prompt.md">design brief</a> in the repository.</div>
      </section>
      <section>
        <h2>Minimum V1 experience</h2>
        <div class="grid">
          <article class="card"><span class="badge">Search</span><h3>Fast lookup</h3><p>Search by tartan name with category and date filters.</p></article>
          <article class="card"><span class="badge">Browse</span><h3>A–Z and categories</h3><p>Help people explore without knowing the exact name.</p></article>
          <article class="card"><span class="badge">Detail</span><h3>Clear source record</h3><p>Show image, metadata, reference ID, and official source link.</p></article>
          <article class="card"><span class="badge">Trust</span><h3>Attribution first</h3><p>Make unofficial status and authoritative source clear everywhere.</p></article>
        </div>
      </section>
      <section>
        <h2>Sample record</h2>
        {sample.map((t) => <article class="card"><img src={t.imageUrl} alt={`Tartan pattern for ${t.name}`} width="220" height="220" loading="lazy" /><h3>{t.name}</h3><p><strong>Ref:</strong> {t.ref}</p><p><strong>Category:</strong> {t.category}</p><p><a href={t.sourceUrl}>Official Register record</a></p></article>)}
      </section>
    </main>
    <footer class="wrap footer">Unofficial helper. The Scottish Register of Tartans remains the authoritative source.</footer>
  </body>
</html>
