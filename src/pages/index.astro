---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Scottish Tartan Finder</title>
    <meta name="description" content="An independent, unofficial catalogue for searching and browsing Scottish tartans, attributed to the Scottish Register of Tartans." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Libre+Franklin:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="app"></div>
    <script is:inline>
      // ponytail: design's own 11-item sample embedded verbatim from the .dc.html prototype.
      // Swap for generated data/tartans-index.json when the indexer lands (same field shape).
      const TARTANS = [
        { name:'Anderson', ref:'1043', cat:'Clan/Family', designer:'', tartanDate:'c. 1906', regDate:'12 May 2009', restrictions:'', notes:'A long-standing family tartan; woven reference held in the Register archive.' },
        { name:'Black Watch', ref:'2932', cat:'Military', designer:'', tartanDate:'c. 1725', regDate:'3 Feb 2008', restrictions:'', notes:'One of the oldest documented military setts, associated with Highland regiments.' },
        { name:'Caledonia', ref:'1216', cat:'District', designer:'', tartanDate:'c. 1831', regDate:'19 Sep 2010', restrictions:'', notes:'A general Scottish district design, historically worn without clan affiliation.' },
        { name:'Dress Stewart', ref:'0302', cat:'Fashion', designer:'', tartanDate:'19th century', regDate:'8 Nov 2007', restrictions:'', notes:'A light “dress” variation developed for formal and dancewear.' },
        { name:'Edinburgh City', ref:'4501', cat:'District', designer:'Kinloch Anderson', tartanDate:'1996', regDate:'22 Jun 2012', restrictions:'', notes:'Commissioned to represent the city of Edinburgh; freely available for wear.' },
        { name:'Flower of Scotland', ref:'1988', cat:'Corporate', designer:'', tartanDate:'1974', regDate:'14 Mar 2009', restrictions:'', notes:'A widely recognised commemorative sett tied to national identity.' },
        { name:'Galloway', ref:'3120', cat:'District', designer:'', tartanDate:'c. 1950', regDate:'5 Aug 2011', restrictions:'', notes:'Represents the Galloway region of south-west Scotland.' },
        { name:'Hunting MacLeod', ref:'0776', cat:'Clan/Family', designer:'', tartanDate:'c. 1810', regDate:'27 Jan 2008', restrictions:'', notes:'A muted “hunting” variation of the MacLeod sett, in greens and blues.' },
        { name:'Isle of Skye', ref:'4200', cat:'District', designer:'Rosemary Nicolson Samios', tartanDate:'1992', regDate:'11 Oct 2010', restrictions:'', notes:'Designed to evoke the landscape and light of the Isle of Skye.' },
        { name:'Jubilee', ref:'5500', cat:'Commemorative', designer:'House of Edgar', tartanDate:'2002', regDate:'2 Jun 2012', restrictions:'Restricted — woven for a specific commission. Permission from the designer is required before reproduction.', notes:'A commemorative registration marking a national anniversary.' },
        { name:'Kintyre', ref:'2810', cat:'District', designer:'', tartanDate:'', regDate:'30 Apr 2011', restrictions:'', notes:'Represents the Kintyre peninsula; design date not recorded in the Register.' }
      ];
      TARTANS.forEach(t => { t.letter = t.name[0].toUpperCase(); });

      const GITHUB_URL = 'https://github.com/scottish-tartan-finder/catalogue';
      const REGISTER_URL = 'https://www.tartanregister.gov.uk';

      const state = { page:'home', query:'', cat:'All', sort:'name', detailId:null, lightbox:false, azLetter:'All', isMobile:false, menuOpen:false };
      const app = document.getElementById('app');

      const esc = (s) => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      function set(patch){ Object.assign(state, patch); render(); }
      function open(ref){ set({ page:'detail', detailId:ref, lightbox:false, menuOpen:false }); window.scrollTo(0,0); }

      // ---------- shared bits ----------
      const previewSwatch = `<div style="aspect-ratio:4/3;background:#e9e1cf;background-image:repeating-linear-gradient(135deg,#e2d8bd 0 7px,#ece5d3 7px 15px);display:flex;align-items:flex-end;padding:10px;">
        <span style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.06em;color:#8a7d5f;background:rgba(251,248,241,.85);padding:3px 7px;border:1px solid #ded3ba;">tartan preview</span></div>`;

      function cardHTML(t, cta){
        const meta = [t.designer, t.tartanDate].filter(Boolean).join(' · ');
        return `<div class="tf-card" data-act="open" data-arg="${t.ref}">
          ${previewSwatch}
          <div style="padding:15px 16px 18px;">
            <span style="display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:500;letter-spacing:.09em;text-transform:uppercase;color:#2f5140;background:#eef0e7;border:1px solid #d9dcc9;padding:3px 8px;">${esc(t.cat)}</span>
            <h3 style="font-size:1.55rem;line-height:1.08;margin:11px 0 5px;">${esc(t.name)}</h3>
            <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:#8a7d5f;">Ref ${esc(t.ref)}</div>
            ${meta ? `<div style="font-size:13px;color:#6b6455;margin-top:7px;">${esc(meta)}</div>` : ''}
            ${cta ? `<div style="margin-top:13px;font-size:13px;font-weight:600;color:#2f5140;">View details →</div>` : ''}
          </div></div>`;
      }
      const grid = (inner, min=240) => `<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(${min}px,1fr));gap:18px;">${inner}</div>`;

      // ---------- header / footer ----------
      function headerHTML(){
        const nav = (act,label,on) => `<span data-act="${act}" style="cursor:pointer;font-size:14px;font-weight:${on?600:500};color:${on?'#211d16':'#6b6455'};padding-bottom:3px;border-bottom:2px solid ${on?'#2f5140':'transparent'};">${label}</span>`;
        const desktopNav = `<nav style="display:flex;align-items:center;gap:clamp(14px,2.4cqw,28px);flex-wrap:wrap;">
          ${nav('goResults','Search',state.page==='results')}
          ${nav('goBrowse','Browse A–Z',state.page==='browse')}
          ${nav('goCats','Categories',state.page==='categories')}
          ${nav('goAbout','About',state.page==='about')}
          <a href="${GITHUB_URL}" target="_blank" rel="noopener" style="font-size:14px;font-weight:500;color:#6b6455;display:inline-flex;align-items:center;gap:5px;">GitHub<span style="font-size:11px;">↗</span></a>
        </nav>`;
        const burger = `<button data-act="toggleMenu" aria-label="Menu" style="flex-shrink:0;width:46px;height:46px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;background:transparent;border:1px solid #d8cdb4;border-radius:3px;cursor:pointer;">
          <span style="width:20px;height:2px;background:#3a3428;display:block;"></span><span style="width:20px;height:2px;background:#3a3428;display:block;"></span><span style="width:20px;height:2px;background:#3a3428;display:block;"></span></button>`;
        const mNav = (act,label) => `<span data-act="${act}" style="padding:15px 4px;font-size:17px;font-weight:600;color:#211d16;border-bottom:1px solid #e8e0cd;cursor:pointer;">${label}</span>`;
        const mobileMenu = state.menuOpen ? `<nav style="border-top:1px solid #e0d7c3;background:#f6f1e7;padding:8px clamp(18px,5cqw,48px) 16px;display:flex;flex-direction:column;">
          ${mNav('goResults','Search')}${mNav('goBrowse','Browse A–Z')}${mNav('goCats','Categories')}${mNav('goAbout','About')}
          <a href="${GITHUB_URL}" target="_blank" rel="noopener" style="padding:15px 4px;font-size:17px;font-weight:600;color:#2f5140;">GitHub ↗</a></nav>` : '';
        return `<header style="position:sticky;top:0;z-index:40;background:rgba(246,241,231,.92);backdrop-filter:blur(10px);border-bottom:1px solid #e0d7c3;">
          <div style="max-width:1180px;margin:0 auto;padding:14px clamp(18px,5cqw,48px);display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:nowrap;">
            <div data-act="goHome" style="display:flex;align-items:center;gap:11px;cursor:pointer;min-width:0;">
              <div style="width:34px;height:34px;border:1.5px solid #2f5140;display:flex;align-items:center;justify-content:center;">
                <div style="width:16px;height:16px;background:repeating-linear-gradient(0deg,#2f5140 0 3px,transparent 3px 6px),repeating-linear-gradient(90deg,#6d2532 0 3px,transparent 3px 6px);opacity:.85;"></div></div>
              <div style="line-height:1;">
                <div style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;letter-spacing:.01em;">Scottish Tartan Finder</div>
                <div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:#8a7d5f;margin-top:3px;">Unofficial reference catalogue</div></div></div>
            ${state.isMobile ? burger : desktopNav}
          </div>
          ${mobileMenu}
        </header>`;
      }

      function footerHTML(){
        const link = (act,label) => `<span data-act="${act}" style="font-size:14px;color:#cfc7b6;cursor:pointer;">${label}</span>`;
        return `<footer style="background:#20241f;color:#cfc7b6;">
          <div style="height:3px;background:repeating-linear-gradient(90deg,#223851 0 22px,#2f5140 22px 30px,#6d2532 30px 52px,#a67c2e 52px 58px);opacity:.85;"></div>
          <div style="max-width:1180px;margin:0 auto;padding:clamp(40px,5cqw,60px) clamp(18px,5cqw,48px) 30px;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:34px;">
            <div style="max-width:34ch;">
              <div style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:#f0e9d8;">Scottish Tartan Finder</div>
              <p style="font-size:13.5px;line-height:1.7;color:#a49c8a;margin:12px 0 0;">An independent, unofficial catalogue for searching and understanding Scottish tartans.</p></div>
            <div><div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#7d765f;margin-bottom:14px;">Browse</div>
              <div style="display:flex;flex-direction:column;gap:10px;">${link('goResults','Search')}${link('goBrowse','Browse A–Z')}${link('goCats','Categories')}${link('goAbout','About')}</div></div>
            <div><div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#7d765f;margin-bottom:14px;">Source</div>
              <div style="display:flex;flex-direction:column;gap:10px;">
                <a href="${REGISTER_URL}" target="_blank" rel="noopener" style="font-size:14px;color:#cfc7b6;">Scottish Register of Tartans ↗</a>
                <a href="${GITHUB_URL}" target="_blank" rel="noopener" style="font-size:14px;color:#cfc7b6;">Project on GitHub ↗</a></div></div>
          </div>
          <div style="max-width:1180px;margin:0 auto;padding:0 clamp(18px,5cqw,48px) 40px;">
            <p style="font-size:12px;line-height:1.7;color:#8a8270;border-top:1px solid #34382f;padding-top:22px;margin:0;">Scottish Tartan Finder is not affiliated with, endorsed by, or connected to the Scottish Register of Tartans or the National Records of Scotland. Tartan records are attributed to the Scottish Register of Tartans. © 2026 Scottish Tartan Finder — unofficial reference project.</p></div>
        </footer>`;
      }

      // ---------- views ----------
      function homeHTML(){
        const recent = ['4200','4501','5500'].map(r=>TARTANS.find(t=>t.ref===r)).filter(Boolean).map(t=>cardHTML(t,false)).join('');
        const step = (n,color,h,p) => `<div><div style="font-family:'IBM Plex Mono',monospace;font-size:26px;color:${color};">${n}</div>
          <h3 style="font-size:1.55rem;margin:8px 0 8px;">${h}</h3>
          <p style="font-size:15px;line-height:1.6;color:#5c5647;margin:0;">${p}</p></div>`;
        return `<div>
          <section style="position:relative;background:radial-gradient(130% 100% at 50% -10%,#3b424a 0%,#242a30 45%,#171b20 100%);color:#ece4d3;overflow:hidden;">
            <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(115deg,rgba(255,255,255,.028) 0 2px,transparent 2px 24px);pointer-events:none;"></div>
            <div style="max-width:1180px;margin:0 auto;padding:clamp(48px,9cqw,104px) clamp(18px,5cqw,48px) clamp(40px,7cqw,80px);position:relative;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:#c9b98a;margin-bottom:22px;">Search · Browse · Understand</div>
              <h1 style="font-size:clamp(2.9rem,9.5cqw,7.2rem);line-height:.94;font-weight:600;letter-spacing:-.01em;margin:0;max-width:14ch;">The tartans of Scotland, in one place.</h1>
              <p style="max-width:56ch;margin:26px 0 0;font-size:clamp(15px,1.6cqw,18px);line-height:1.6;color:#cfc7b6;">A calm, readable catalogue for exploring Scottish tartans — search by name, clan, district or reference, and read the record behind each design. Built from public data attributed to the Scottish Register of Tartans.</p>
              <div style="margin-top:34px;max-width:640px;">
                <div style="display:flex;background:#f6f1e7;border:1px solid #d8cdb4;border-radius:2px;overflow:hidden;box-shadow:0 18px 40px -24px rgba(0,0,0,.6);">
                  <input id="q" value="${esc(state.query)}" placeholder="Search tartans — e.g. “MacLeod”, “district”, ref 4200" style="flex:1;border:none;outline:none;background:transparent;padding:17px 20px;font-size:16px;color:#211d16;" />
                  <button data-act="goResults" style="border:none;background:#2f5140;color:#f6f1e7;padding:0 26px;font-weight:600;font-size:15px;letter-spacing:.02em;cursor:pointer;">Search</button></div>
                <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:16px;">
                  <button data-act="goBrowse" style="background:rgba(246,241,231,.08);border:1px solid rgba(236,228,211,.32);color:#ece4d3;padding:11px 20px;font-size:14px;font-weight:500;cursor:pointer;border-radius:2px;">Browse A–Z</button>
                  <button data-act="goCats" style="background:rgba(246,241,231,.08);border:1px solid rgba(236,228,211,.32);color:#ece4d3;padding:11px 20px;font-size:14px;font-weight:500;cursor:pointer;border-radius:2px;">Browse by category</button></div></div>
              <p style="margin:30px 0 0;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.05em;color:rgba(236,228,211,.55);max-width:60ch;line-height:1.7;">Unofficial project — not affiliated with the Scottish Register of Tartans. Records attributed to the official Register.</p>
            </div></section>
          <section style="max-width:1180px;margin:0 auto;padding:clamp(44px,6cqw,72px) clamp(18px,5cqw,48px);">
            <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:26px;">
              <div><div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8a7d5f;margin-bottom:8px;">Newly discovered</div>
                <h2 style="font-size:clamp(1.9rem,3.6cqw,2.7rem);line-height:1.05;">Recently added to the catalogue</h2></div>
              <span data-act="goBrowse" style="font-size:14px;font-weight:600;color:#2f5140;cursor:pointer;white-space:nowrap;">See all ${TARTANS.length} tartans →</span></div>
            ${grid(recent,230)}</section>
          <section style="border-top:1px solid #e0d7c3;background:#efe8db;">
            <div style="max-width:1180px;margin:0 auto;padding:clamp(40px,5cqw,60px) clamp(18px,5cqw,48px);display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:34px;">
              ${step('01','#6d2532','Search plainly','Type a name, clan, district or reference number. Results filter as you go — no accounts, no clutter.')}
              ${step('02','#2f5140','Read the record','Each tartan shows category, designer, dates and any restrictions — with a clear link to the official Register entry.')}
              ${step('03','#a67c2e','Always attributed','This is an independent reference. Every record credits its source, and we never present ourselves as official.')}
            </div></section>
        </div>`;
      }

      function filtered(){
        const q = state.query.trim().toLowerCase();
        let list = TARTANS.filter(t => {
          const okQ = !q || t.name.toLowerCase().includes(q) || t.ref.includes(q) || (t.designer||'').toLowerCase().includes(q) || t.cat.toLowerCase().includes(q);
          const okC = state.cat==='All' || t.cat===state.cat;
          return okQ && okC;
        });
        if (state.sort==='name') list.sort((a,b)=>a.name.localeCompare(b.name));
        else if (state.sort==='ref') list.sort((a,b)=>Number(a.ref)-Number(b.ref));
        else if (state.sort==='cat') list.sort((a,b)=>a.cat.localeCompare(b.cat)||a.name.localeCompare(b.name));
        return list;
      }
      function catCounts(){ const c={}; TARTANS.forEach(t=>c[t.cat]=(c[t.cat]||0)+1); return c; }

      function resultsHTML(){
        const list = filtered();
        const counts = catCounts();
        const cats = ['All', ...Object.keys(counts).sort()];
        const chips = cats.map(c=>{
          const a = state.cat===c;
          return `<span data-act="setCat" data-arg="${esc(c)}" style="cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.06em;text-transform:uppercase;padding:7px 12px;border-radius:2px;border:1px solid ${a?'#2f5140':'#d8cdb4'};background:${a?'#2f5140':'#faf6ec'};color:${a?'#f6f1e7':'#6b6455'};">${esc(c)}</span>`;
        }).join('');
        const q = state.query.trim();
        const label = list.length + (list.length===1?' tartan':' tartans') + (state.cat!=='All'?' in '+state.cat:'') + (q?' matching “'+q+'”':'');
        const opt = (v,l) => `<option value="${v}"${state.sort===v?' selected':''}>${l}</option>`;
        const body = list.length
          ? grid(list.map(t=>cardHTML(t,true)).join(''))
          : `<div style="text-align:center;padding:64px 24px;border:1px dashed #d3c8ae;border-radius:4px;background:#faf6ec;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#8a7d5f;">No matches</div>
              <h3 style="font-size:1.9rem;margin:12px 0 8px;">Nothing found for that search</h3>
              <p style="color:#6b6455;max-width:44ch;margin:0 auto 22px;line-height:1.6;">Try a shorter term, a clan or district name, or clear the filters to see the full catalogue.</p>
              <button data-act="clearFilters" style="background:#2f5140;color:#f6f1e7;border:none;padding:12px 24px;font-weight:600;font-size:14px;cursor:pointer;border-radius:2px;">Clear search &amp; filters</button></div>`;
        return `<div style="max-width:1180px;margin:0 auto;padding:clamp(30px,4cqw,52px) clamp(18px,5cqw,48px) 72px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8a7d5f;margin-bottom:10px;">Search the catalogue</div>
          <h1 style="font-size:clamp(2.2rem,5cqw,3.4rem);line-height:1.02;margin-bottom:22px;">Find a tartan</h1>
          <div style="display:flex;background:#fbf8f1;border:1px solid #d8cdb4;border-radius:2px;overflow:hidden;max-width:640px;">
            <input id="q" value="${esc(state.query)}" placeholder="Search by name, clan, district or reference…" style="flex:1;border:none;outline:none;background:transparent;padding:15px 18px;font-size:16px;color:#211d16;" />
            <div style="display:flex;align-items:center;padding:0 16px;font-family:'IBM Plex Mono',monospace;font-size:12px;color:#8a7d5f;border-left:1px solid #e4dcc9;">↵</div></div>
          <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin:26px 0 8px;padding-bottom:18px;border-bottom:1px solid #e0d7c3;">
            <div style="display:flex;gap:8px;flex-wrap:wrap;">${chips}</div>
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;color:#8a7d5f;text-transform:uppercase;">Sort</span>
              <select id="sort" style="border:1px solid #d8cdb4;background:#fbf8f1;padding:9px 12px;font-size:14px;color:#211d16;border-radius:2px;cursor:pointer;">${opt('name','Name A–Z')}${opt('ref','Reference ID')}${opt('cat','Category')}</select></div></div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#6b6455;margin:14px 0 22px;">${esc(label)}</div>
          ${body}</div>`;
      }

      function browseHTML(){
        const counts={}; TARTANS.forEach(t=>counts[t.letter]=(counts[t.letter]||0)+1);
        const alpha='ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
        const azStyle=(active,disabled)=>`min-width:34px;text-align:center;cursor:${disabled?'default':'pointer'};font-family:'IBM Plex Mono',monospace;font-size:13px;padding:8px 6px;border-radius:2px;background:${active?'#2f5140':'transparent'};color:${disabled?'#c3b89e':(active?'#f6f1e7':'#3a3428')};border:1px solid ${active?'#2f5140':'transparent'};`;
        const navItems=[{label:'All',letter:'All',count:1},...alpha.map(l=>({label:l,letter:l,count:counts[l]||0}))].map(o=>{
          const disabled=o.letter!=='All'&&o.count===0;
          return `<span ${disabled?'':`data-act="setLetter" data-arg="${o.letter}"`} style="${azStyle(state.azLetter===o.letter,disabled)}">${o.label}</span>`;
        }).join('');
        const src=state.azLetter==='All'?TARTANS:TARTANS.filter(t=>t.letter===state.azLetter);
        const letters=[...new Set(src.map(t=>t.letter))].sort();
        const groups=letters.map(L=>{
          const items=src.filter(t=>t.letter===L).sort((a,b)=>a.name.localeCompare(b.name)).map(t=>cardHTML(t,false)).join('');
          return `<div style="margin-bottom:38px;">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:18px;">
              <div style="font-family:'Cormorant Garamond',serif;font-size:2.4rem;font-weight:700;color:#2f5140;line-height:1;">${L}</div>
              <div style="flex:1;height:1px;background:#e0d7c3;"></div></div>
            ${grid(items)}</div>`;
        }).join('');
        return `<div style="max-width:1180px;margin:0 auto;padding:clamp(30px,4cqw,52px) clamp(18px,5cqw,48px) 72px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8a7d5f;margin-bottom:10px;">Alphabetical index</div>
          <h1 style="font-size:clamp(2.2rem,5cqw,3.4rem);line-height:1.02;margin-bottom:8px;">Browse A–Z</h1>
          <p style="color:#6b6455;max-width:56ch;line-height:1.6;margin:0 0 26px;">Every tartan in the catalogue, ordered by name. Jump to a letter or scroll the full list.</p>
          <div style="display:flex;flex-wrap:wrap;gap:6px;padding:16px;background:#faf6ec;border:1px solid #e4dcc9;border-radius:3px;margin-bottom:34px;">${navItems}</div>
          ${groups}</div>`;
      }

      function catsHTML(){
        const counts=catCounts();
        const cards=Object.keys(counts).sort().map(c=>`<div class="tf-catcard" data-act="catCard" data-arg="${esc(c)}">
          <div style="position:absolute;top:0;right:0;width:70px;height:70px;background:repeating-linear-gradient(45deg,#e6dcc3 0 5px,#efe8d6 5px 10px);opacity:.6;"></div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:#8a7d5f;">${counts[c]} tartans</div>
          <h3 style="font-size:1.85rem;line-height:1.08;margin:8px 0 14px;max-width:12ch;">${esc(c)}</h3>
          <div style="font-size:14px;font-weight:600;color:#2f5140;">View tartans →</div></div>`).join('');
        return `<div style="max-width:1180px;margin:0 auto;padding:clamp(30px,4cqw,52px) clamp(18px,5cqw,48px) 72px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8a7d5f;margin-bottom:10px;">Browse by type</div>
          <h1 style="font-size:clamp(2.2rem,5cqw,3.4rem);line-height:1.02;margin-bottom:8px;">Categories</h1>
          <p style="color:#6b6455;max-width:58ch;line-height:1.6;margin:0 0 32px;">Tartans in the Register are grouped by their purpose and origin — from clan and family designs to districts, corporate, military and commemorative registrations.</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px;">${cards}</div></div>`;
      }

      function detailHTML(){
        const d=TARTANS.find(t=>t.ref===state.detailId);
        if(!d) return resultsHTML();
        const row=(dt,dd)=>`<div style="display:grid;grid-template-columns:minmax(120px,180px) 1fr;gap:16px;padding:15px 0;border-bottom:1px solid #e0d7c3;">
          <dt style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#8a7d5f;">${dt}</dt>
          <dd style="margin:0;font-size:15px;line-height:1.6;color:#211d16;">${dd}</dd></div>`;
        const restr = d.restrictions ? `<div style="margin-bottom:24px;padding:15px 18px;border:1px solid #dcbdc0;background:#f6ebe9;border-radius:3px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#6d2532;margin-bottom:6px;">Restrictions</div>
          <p style="margin:0;font-size:14px;line-height:1.6;color:#5a3a3d;">${esc(d.restrictions)}</p></div>` : '';
        const sourceUrl = REGISTER_URL+'/tartanDetails?ref='+d.ref;
        const similar = TARTANS.filter(t=>t.cat===d.cat&&t.ref!==d.ref).slice(0,3).map(t=>`<div class="tf-card" data-act="open" data-arg="${t.ref}">
          ${previewSwatch}
          <div style="padding:14px 15px 16px;"><h3 style="font-size:1.4rem;line-height:1.1;margin:0 0 5px;">${esc(t.name)}</h3>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#8a7d5f;">Ref ${esc(t.ref)}</div></div></div>`).join('');
        return `<div style="max-width:1180px;margin:0 auto;padding:clamp(24px,3cqw,40px) clamp(18px,5cqw,48px) 72px;">
          <span data-act="goResults" style="display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:500;color:#6b6455;cursor:pointer;margin-bottom:26px;">← Back to search</span>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(28px,4cqw,48px);align-items:start;">
            <div>
              <div style="aspect-ratio:1/1;background:#e9e1cf;background-image:repeating-linear-gradient(135deg,#e0d6ba 0 9px,#ece5d3 9px 19px);border:1px solid #e4dcc9;border-radius:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;position:relative;">
                <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.1em;color:#8a7d5f;background:rgba(251,248,241,.9);padding:6px 12px;border:1px solid #ded3ba;">tartan pattern preview</span>
                <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:#a89b7c;">image not yet available</span></div>
              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;">
                <button data-act="openImg" style="flex:1;min-width:150px;background:#2f5140;color:#f6f1e7;border:none;padding:13px 18px;font-weight:600;font-size:14px;cursor:pointer;border-radius:2px;">Open tartan image ↗</button>
                <a href="${sourceUrl}" target="_blank" rel="noopener" style="flex:1;min-width:150px;text-align:center;background:transparent;border:1px solid #cdbf9f;color:#3a3428;padding:13px 18px;font-weight:600;font-size:14px;border-radius:2px;">Official Register ↗</a></div>
              <div style="margin-top:18px;padding:16px 18px;border:1px solid #e0d7c3;background:#faf6ec;border-radius:3px;">
                <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#a67c2e;margin-bottom:7px;">Similar tartans · coming soon</div>
                <p style="margin:0;font-size:13px;line-height:1.6;color:#6b6455;">Visual matching against related designs is planned for a future release. For now, browse others in this category below.</p></div></div>
            <div>
              <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.08em;color:#8a7d5f;margin-bottom:12px;">Ref ${esc(d.ref)} · Scottish Register of Tartans</div>
              <h1 style="font-size:clamp(2.6rem,6cqw,4.4rem);line-height:.98;letter-spacing:-.01em;">${esc(d.name)}</h1>
              <div style="margin:16px 0 26px;"><span style="display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:#2f5140;background:#eef0e7;border:1px solid #d9dcc9;padding:5px 11px;">${esc(d.cat)}</span></div>
              ${restr}
              <dl style="margin:0;border-top:1px solid #e0d7c3;">
                ${row('Reference ID',esc(d.ref))}
                ${row('Category',esc(d.cat))}
                ${row('Designer',esc(d.designer||'Not recorded'))}
                ${row('Tartan date',esc(d.tartanDate||'Not recorded'))}
                ${row('Registration date',esc(d.regDate||'Not recorded'))}
                ${row('Notes',esc(d.notes||'—'))}</dl>
              <div style="margin-top:26px;padding:18px 20px;border:1px solid #d3c8ae;background:#efe8db;border-radius:3px;">
                <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#8a7d5f;margin-bottom:8px;">Source &amp; disclaimer</div>
                <p style="margin:0;font-size:13.5px;line-height:1.7;color:#5c5647;">This record is attributed to the <a href="${REGISTER_URL}" target="_blank" rel="noopener" style="font-weight:600;">Scottish Register of Tartans</a>. Scottish Tartan Finder is an independent, unofficial project and is not affiliated with or endorsed by the Register. Always consult the official entry for authoritative details.</p></div></div></div>
          <div style="margin-top:56px;">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;"><h2 style="font-size:1.9rem;">More in ${esc(d.cat)}</h2><div style="flex:1;height:1px;background:#e0d7c3;"></div></div>
            ${grid(similar,230)}</div></div>`;
      }

      function aboutHTML(){
        return `<div>
          <section style="position:relative;background:radial-gradient(130% 120% at 30% -20%,#3b424a 0%,#242a30 50%,#171b20 100%);color:#ece4d3;overflow:hidden;">
            <div style="position:absolute;inset:0;background-image:repeating-linear-gradient(115deg,rgba(255,255,255,.028) 0 2px,transparent 2px 24px);pointer-events:none;"></div>
            <div style="max-width:1180px;margin:0 auto;padding:clamp(48px,7cqw,88px) clamp(18px,5cqw,48px);position:relative;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:#c9b98a;margin-bottom:20px;">About the project</div>
              <h1 style="font-size:clamp(2.6rem,7cqw,5rem);line-height:.98;max-width:16ch;">A respectful, independent window on Scottish tartan.</h1></div></section>
          <section style="max-width:820px;margin:0 auto;padding:clamp(44px,6cqw,72px) clamp(18px,5cqw,48px);">
            <p style="font-size:clamp(17px,2cqw,20px);line-height:1.7;color:#3a3428;margin:0 0 22px;">Scottish Tartan Finder is a static, community reference catalogue for exploring Scottish tartans. It exists to make public tartan records easier to search, read and understand — with plain typography, no accounts, and no clutter.</p>
            <p style="font-size:16px;line-height:1.75;color:#5c5647;margin:0 0 34px;">The catalogue is intentionally modest in scope: it presents attributed public information and links back to authoritative sources rather than trying to replace them.</p>
            <div style="padding:24px 26px;border:1px solid #d3c8ae;background:#efe8db;border-radius:3px;margin-bottom:34px;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#8a7d5f;margin-bottom:12px;">Source attribution</div>
              <p style="margin:0 0 14px;font-size:15px;line-height:1.75;color:#3a3428;">Tartan records shown here are attributed to the <strong>Scottish Register of Tartans</strong>, maintained by the National Records of Scotland. Where available, each entry links to its official Register page so you can verify the authoritative record.</p>
              <a href="${REGISTER_URL}" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;font-weight:600;font-size:15px;">Visit the Scottish Register of Tartans ↗</a></div>
            <div style="padding:24px 26px;border:1px solid #dcbdc0;background:#f6ebe9;border-radius:3px;margin-bottom:40px;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:#6d2532;margin-bottom:12px;">Unofficial — please read</div>
              <p style="margin:0;font-size:15px;line-height:1.75;color:#5a3a3d;">Scottish Tartan Finder is an <strong>independent, unofficial project</strong>. It is not affiliated with, endorsed by, or connected to the Scottish Register of Tartans, the National Records of Scotland, or any government body. Information may be incomplete or out of date — for authoritative details, always consult the official Register.</p></div>
            <h2 style="font-size:2rem;margin-bottom:16px;">How it works</h2>
            <p style="font-size:16px;line-height:1.75;color:#5c5647;margin:0 0 14px;">The site is a static build — search and browsing run entirely in your browser over a published dataset, with no login, no tracking database, and no live backend. That keeps it fast, private, and simple to host.</p>
            <p style="font-size:16px;line-height:1.75;color:#5c5647;margin:0 0 34px;">The project is open source. Contributions, corrections and attribution improvements are welcome.</p>
            <a href="${GITHUB_URL}" target="_blank" rel="noopener" style="display:inline-block;background:#2f5140;color:#f6f1e7;padding:14px 26px;font-weight:600;font-size:15px;border-radius:2px;">View the project on GitHub ↗</a></section></div>`;
      }

      function lightboxHTML(){
        if(!state.lightbox) return '';
        const d=TARTANS.find(t=>t.ref===state.detailId);
        const nm = d?esc(d.name):'';
        return `<div data-act="closeImg" style="position:fixed;inset:0;z-index:80;background:rgba(20,18,14,.86);backdrop-filter:blur(4px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;padding:24px;">
          <div style="width:min(88cqw,560px);aspect-ratio:1/1;background:#e9e1cf;background-image:repeating-linear-gradient(135deg,#dcd1b3 0 11px,#ece5d3 11px 23px);border:1px solid #cdbf9f;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:13px;letter-spacing:.1em;color:#8a7d5f;background:rgba(251,248,241,.9);padding:7px 14px;border:1px solid #ded3ba;">${nm} — pattern preview</span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#a89b7c;">image not yet available</span></div>
          <button data-act="closeImg" style="background:rgba(246,241,231,.12);border:1px solid rgba(236,228,211,.4);color:#ece4d3;padding:11px 22px;font-size:14px;font-weight:500;cursor:pointer;border-radius:2px;">Close</button></div>`;
      }

      const VIEWS = { home:homeHTML, results:resultsHTML, browse:browseHTML, categories:catsHTML, detail:detailHTML, about:aboutHTML };

      const ACTIONS = {
        goHome:()=>set({page:'home',lightbox:false,menuOpen:false}),
        goResults:()=>set({page:'results',lightbox:false,menuOpen:false}),
        goBrowse:()=>set({page:'browse',lightbox:false,menuOpen:false}),
        goCats:()=>set({page:'categories',lightbox:false,menuOpen:false}),
        goAbout:()=>set({page:'about',lightbox:false,menuOpen:false}),
        toggleMenu:()=>set({menuOpen:!state.menuOpen}),
        open:(ref)=>open(ref),
        setCat:(c)=>set({cat:c}),
        catCard:(c)=>set({page:'results',cat:c,query:''}),
        setLetter:(l)=>set({azLetter:l}),
        clearFilters:()=>set({query:'',cat:'All'}),
        openImg:()=>set({lightbox:true}),
        closeImg:()=>set({lightbox:false})
      };

      function render(){
        // preserve focus/caret on the search input across re-render
        const active = document.activeElement;
        const keepFocus = active && active.id === 'q';
        const caret = keepFocus ? active.selectionStart : null;

        app.innerHTML = headerHTML() + `<main style="flex:1;">${(VIEWS[state.page]||homeHTML)()}</main>` + footerHTML() + lightboxHTML();

        if (keepFocus){ const q=document.getElementById('q'); if(q){ q.focus(); try{ q.setSelectionRange(caret,caret); }catch(e){} } }

        const q = document.getElementById('q');
        if (q){
          q.addEventListener('input', e=>{ state.query=e.target.value; if(state.page==='results') render(); });
          q.addEventListener('keydown', e=>{ if(e.key==='Enter'){ if(state.page!=='results') set({page:'results'}); } });
        }
        const sort = document.getElementById('sort');
        if (sort) sort.addEventListener('change', e=>set({sort:e.target.value}));
      }

      // event delegation for data-act elements
      app.addEventListener('click', e=>{
        const el = e.target.closest('[data-act]');
        if(!el) return;
        const fn = ACTIONS[el.dataset.act];
        if(fn){ e.preventDefault(); fn(el.dataset.arg); }
      });

      function onResize(){ const m=window.innerWidth<760; if(m!==state.isMobile) set({isMobile:m,menuOpen:false}); }
      window.addEventListener('resize', onResize);
      state.isMobile = window.innerWidth<760;
      render();
    </script>
  </body>
</html>
